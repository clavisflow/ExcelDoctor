@page "/"
@using ExcelDoctor.Models
@using ExcelDoctor.Services
@inject ExcelWorkbookAnalyzer Analyzer
@inject IJSRuntime JsRuntime

<PageTitle>ClavisFlow | Excel 健康診断</PageTitle>

<section class="diagnostics-shell @(result is null ? "initial" : "has-result")">
    <div class="workspace-title">
        <div>
            <div class="product-brand">
                <span class="brand-mark" aria-hidden="true"><img src="clavisflow-icon.png" alt=""></span>
                <span>ClavisFlow</span>
            </div>
            <h1>Excel 健康診断</h1>
            <p class="lead-copy">
                ファイルをドラッグ＆ドロップするだけ。危険なマクロ、増殖した数式、隠されたシート、依存しているデータベースをブラウザ上で瞬時に解析。機密性を保ったまま、あなたのExcelの「カオス度」を可視化します。
            </p>
        </div>
    </div>

    <div class="upload-panel @(isAnalyzing ? "is-analyzing" : string.Empty)" aria-busy="@isAnalyzing">
        <div class="upload-copy">
            <span class="upload-icon">XL</span>
            <div>
                <label class="upload-label" for="excelFile">Excel ファイルを選択またはドロップ</label>
                <p>.xlsx / .xlsm 対応。最大 50MB。</p>
                <p>ファイルはサーバーに送信されず、すべての解析をブラウザ上で安全に行います。</p>
            </div>
        </div>
        <InputFile id="excelFile" class="@FileInputClass()" OnChange="AnalyzeFileAsync" accept=".xlsx,.xlsm" />

        @if (isAnalyzing)
        {
            <div class="analysis-status" role="status">
                <span class="scan-dot" aria-hidden="true"></span>
                <div>
                    <strong>解析中</strong>
                    <p>シート構造、数式、外部リンク、VBA 痕跡を確認しています</p>
                </div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="status error">@errorMessage</p>
        }
    </div>

    @if (result is not null)
    {
        <section class="result-brief" aria-live="polite">
            <div>
                <span class="brief-label">診断結果</span>
                <h2>@AssessmentTitle(result)</h2>
                <p>@AssessmentSummary(result)</p>
            </div>
            <div class="brief-meta">
                <span>@result.FileName</span>
                <strong>@FormatBytes(result.FileSizeBytes)</strong>
                <div class="report-actions">
                    <button type="button" @onclick="DownloadHtmlReportAsync">HTMLダウンロード</button>
                </div>
            </div>
        </section>

        <section class="dashboard-grid" aria-live="polite">
            <div class="score-panel">
                <div class="score-ring" style="@ScoreRingStyle(result.HealthScore)">
                    <span>@result.HealthScore</span>
                </div>
                <div>
                    <p class="score-label">健康診断スコア</p>
                    <h2>ランク @result.Rank</h2>
                    <p class="score-comment">@ScoreComment(result.HealthScore)</p>
                    <div class="rank-scale" aria-label="ランク基準">
                        @foreach (var rank in RankScale())
                        {
                            <span class="@(rank.Rank == result.Rank ? "active" : string.Empty)">@rank.Rank</span>
                        }
                    </div>
                </div>
            </div>

            <div class="risk-panel">
                <h2>リスク分布</h2>
                @foreach (var item in RiskBars(result))
                {
                    <div class="risk-row">
                        <span>@item.Label</span>
                        <div class="risk-track">
                            <div class="risk-fill" style="width: @item.Percent%"></div>
                        </div>
                        <strong>@item.Percent</strong>
                    </div>
                }
                <p class="risk-note">値が高いほど、棚卸し・仕様化・分離の優先度が高い領域です。</p>
            </div>
        </section>

        <section class="summary-strip">
            <div>
                <span>検出リスク</span>
                <strong>@result.Findings.Count</strong>
            </div>
            <div>
                <span>高リスク</span>
                <strong>@result.Findings.Count(finding => finding.Severity == "High")</strong>
            </div>
            <div>
                <span>マクロ</span>
                <strong>@(result.Vba.HasMacro ? "あり" : "なし")</strong>
            </div>
            <div>
                <span>外部依存</span>
                <strong>@(result.Logic.ExternalLinkCount + result.Vba.DataAccessKeywordCount)</strong>
            </div>
        </section>

        <section class="metric-section">
            <h2>診断メトリクス</h2>
            <div class="metric-grid">
                <MetricCard Label="総シート数" Value="@result.Structure.TotalSheetCount.ToString()" Note="構造規模" />
                <MetricCard Label="非表示シート数" Value="@result.Structure.HiddenSheetCount.ToString()" Note="属人化" Tone="@MetricTone(result.Structure.HiddenSheetCount)" />
                <MetricCard Label="ピボットテーブル" Value="@result.Structure.PivotTableCount.ToString()" Note="集計依存" />
                <MetricCard Label="総数式数" Value="@result.Logic.TotalFormulaCount.ToString()" Note="保守負荷" Tone="@MetricTone(result.Logic.TotalFormulaCount, 300, 1000)" />
                <MetricCard Label="参照関数" Value="@result.Logic.LookupFunctionCount.ToString()" Note="参照複雑度" Tone="@MetricTone(result.Logic.LookupFunctionCount, 50, 100)" />
                <MetricCard Label="揮発性関数" Value="@result.Logic.VolatileFunctionCount.ToString()" Note="再計算負荷" Tone="@MetricTone(result.Logic.VolatileFunctionCount)" />
                <MetricCard Label="外部リンク" Value="@result.Logic.ExternalLinkCount.ToString()" Note="環境依存" Tone="@MetricTone(result.Logic.ExternalLinkCount)" />
                <MetricCard Label="名前定義" Value="@result.Logic.DefinedNameCount.ToString()" Note="隠れた参照" Tone="@MetricTone(result.Logic.DefinedNameCount, 20, 50)" />
                <MetricCard Label="セル結合" Value="@result.Operation.MergedCellCount.ToString()" Note="自動化難度" Tone="@MetricTone(result.Operation.MergedCellCount, 20, 50)" />
                <MetricCard Label="条件付き書式" Value="@result.Operation.ConditionalFormatRuleCount.ToString()" Note="表示ロジック" Tone="@MetricTone(result.Operation.ConditionalFormatRuleCount, 50, 100)" />
                <MetricCard Label="入力規則" Value="@result.Operation.DataValidationCount.ToString()" Note="入力制御" Tone="@MetricTone(result.Operation.DataValidationCount, 50, 100)" />
                <MetricCard Label="保護シート" Value="@result.Operation.ProtectedSheetCount.ToString()" Note="編集制限" Tone="@MetricTone(result.Operation.ProtectedSheetCount)" />
            </div>
        </section>

        <section class="insight-grid">
            <div class="panel">
                <h2>検出されたリスク</h2>
                @if (result.Findings.Count == 0)
                {
                    <p class="muted">大きなリスクは検出されませんでした。</p>
                }
                else
                {
                    <div class="finding-list">
                        @foreach (var finding in result.Findings)
                        {
                            <article class="finding-card @SeverityClass(finding.Severity)">
                                <div>
                                    <span>@finding.Category</span>
                                    <em>@SeverityLabel(finding.Severity)</em>
                                </div>
                                <div>
                                    <strong>@finding.Title</strong>
                                </div>
                                <p>@finding.Detail</p>
                            </article>
                        }
                    </div>
                }
            </div>

            <div class="panel">
                <h2>次に取るべきアクション</h2>
                <ol class="action-list">
                    @foreach (var action in result.RecommendedActions)
                    {
                        <li>@action</li>
                    }
                </ol>
            </div>
        </section>

        <section class="panel">
            <div class="panel-heading">
                <h2>VBA マクロ診断</h2>
                @if (result.Vba.HasMacro)
                {
                    <button class="secondary-button" type="button" @onclick="AnalyzeVbaDetailsAsync" disabled="@isAnalyzingVba">
                        @(isAnalyzingVba ? "VBA 解析中..." : result.Vba.DetailedAnalysisCompleted ? "VBA 詳細解析を再実行" : "VBA 詳細解析を実行")
                    </button>
                }
            </div>
            <p class="panel-intro">@VbaAnalysisNote(result.Vba)</p>
            <div class="metric-grid compact">
                <MetricCard Label="マクロ" Value="@(result.Vba.HasMacro ? "あり" : "なし")" Note="xlsm 判定" Tone="@(result.Vba.HasMacro ? "warn" : string.Empty)" />
                <MetricCard Label="解析方式" Value="@VbaAnalysisModeLabel(result.Vba)" Note="VBA 展開" Tone="@(result.Vba.HasMacro && !result.Vba.DetailedAnalysisCompleted ? "warn" : string.Empty)" />
                <MetricCard Label="モジュール" Value="@result.Vba.ModuleCount.ToString()" Note="VBA 部品数" Tone="@MetricTone(result.Vba.ModuleCount, 8, 20)" />
                <MetricCard Label="VBA 行数" Value="@result.Vba.SourceLineCount.ToString()" Note="展開できた行数" Tone="@MetricTone(result.Vba.SourceLineCount, 300, 1000)" />
                <MetricCard Label="VBA 保護痕跡" Value="@(result.Vba.IsPasswordProtected ? "あり" : "なし")" Note="可視性" Tone="@(result.Vba.IsPasswordProtected ? "danger" : string.Empty)" />
                <MetricCard Label="注意語句" Value="@result.Vba.SuspiciousKeywordCount.ToString()" Note="自動実行等" Tone="@MetricTone(result.Vba.SuspiciousKeywordCount)" />
                <MetricCard Label="外部依存語句" Value="@result.Vba.DataAccessKeywordCount.ToString()" Note="DB/API/Office" Tone="@MetricTone(result.Vba.DataAccessKeywordCount)" />
                <MetricCard Label="固定情報パターン" Value="@result.Vba.PersonalInfoPatternCount.ToString()" Note="URL/UNC/メール" Tone="@MetricTone(result.Vba.PersonalInfoPatternCount)" />
            </div>

            @if (result.Vba.HasMacro && (result.Vba.DetectedKeywords.Count > 0 || result.Vba.DetectedDependencies.Count > 0))
            {
                <h3 class="tag-heading">検出語句</h3>
                <div class="tag-cloud">
                    @foreach (var keyword in result.Vba.DetectedKeywords.Concat(result.Vba.DetectedDependencies).Distinct())
                    {
                        <span>@keyword</span>
                    }
                </div>
            }

            @if (result.Vba.DetectedObjectTargets.Count > 0)
            {
                <h3 class="tag-heading">CreateObject / GetObject の対象</h3>
                <ul class="evidence-list">
                    @foreach (var target in result.Vba.DetectedObjectTargets)
                    {
                        <li>@target</li>
                    }
                </ul>
            }

            @if (result.Vba.DetectedFileTargets.Count > 0)
            {
                <h3 class="tag-heading">対象ファイル・パス候補</h3>
                <ul class="evidence-list">
                    @foreach (var path in result.Vba.DetectedFileTargets)
                    {
                        <li>@path</li>
                    }
                </ul>
            }

            @if (result.Vba.DetectedConnectionHints.Count > 0)
            {
                <h3 class="tag-heading">接続先ヒント</h3>
                <div class="tag-cloud">
                    @foreach (var hint in result.Vba.DetectedConnectionHints)
                    {
                        <span>@hint</span>
                    }
                </div>
            }

            @if (result.Vba.DetectedSqlTables.Count > 0)
            {
                <h3 class="tag-heading">SQL テーブル候補</h3>
                <ul class="evidence-list">
                    @foreach (var table in result.Vba.DetectedSqlTables)
                    {
                        <li>@table</li>
                    }
                </ul>
            }

            @if (result.Vba.Modules.Count > 0)
            {
                <h3 class="tag-heading">モジュール別リスク</h3>
                <div class="vba-module-list">
                    @foreach (var module in result.Vba.Modules.OrderByDescending(ModuleRiskScore).ThenBy(module => module.Name).Take(12))
                    {
                        <article class="vba-module-card">
                            <div>
                                <strong>@module.Name</strong>
                                <span>@module.LineCount 行</span>
                            </div>
                            <p>@ModuleSummary(module)</p>
                            @if (module.DetectedKeywords.Count > 0 || module.DetectedDependencies.Count > 0 || module.DetectedSqlTables.Count > 0)
                            {
                                <small>@ModuleDetails(module)</small>
                            }
                        </article>
                    }
                </div>
            }
        </section>
    }
</section>

@code {
    private ExcelDiagnosticsResult? result;
    private IBrowserFile? selectedFile;
    private bool isAnalyzing;
    private bool isAnalyzingVba;
    private string? errorMessage;

    private async Task AnalyzeFileAsync(InputFileChangeEventArgs args)
    {
        result = null;
        errorMessage = null;
        selectedFile = args.File;
        isAnalyzing = true;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        try
        {
            result = await Analyzer.AnalyzeAsync(args.File);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isAnalyzing = false;
        }
    }

    private async Task AnalyzeVbaDetailsAsync()
    {
        if (selectedFile is null)
        {
            errorMessage = "VBA 詳細解析を実行するには、もう一度 Excel ファイルを選択してください。";
            return;
        }

        errorMessage = null;
        isAnalyzingVba = true;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        try
        {
            result = await Analyzer.AnalyzeAsync(selectedFile, includeVbaDetails: true);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isAnalyzingVba = false;
        }
    }

    private async Task DownloadHtmlReportAsync()
    {
        if (result is null)
        {
            return;
        }

        await JsRuntime.InvokeVoidAsync("excelDoctorReport.downloadHtmlReport", BuildReportData(result));
    }

    private static string FormatBytes(long bytes)
    {
        var megabytes = bytes / 1024d / 1024d;
        return $"{megabytes:N2} MB";
    }

    private string FileInputClass() => isAnalyzing ? "file-input disabled" : "file-input";

    private static object BuildReportData(ExcelDiagnosticsResult result)
    {
        return new
        {
            generatedAt = DateTimeOffset.Now.ToString("yyyy/MM/dd HH:mm"),
            fileName = result.FileName,
            fileSize = FormatBytes(result.FileSizeBytes),
            healthScore = result.HealthScore,
            rank = result.Rank,
            assessmentTitle = AssessmentTitle(result),
            assessmentSummary = AssessmentSummary(result),
            scoreComment = ScoreComment(result.HealthScore),
            riskBars = RiskBars(result).Select(item => new { label = item.Label, percent = item.Percent }),
            summary = new
            {
                findingCount = result.Findings.Count,
                highFindingCount = result.Findings.Count(finding => finding.Severity == "High"),
                hasMacro = result.Vba.HasMacro ? "あり" : "なし",
                externalDependencyCount = result.Logic.ExternalLinkCount + result.Vba.DataAccessKeywordCount
            },
            metrics = BuildReportMetrics(result),
            findings = result.Findings.Select(finding => new
            {
                finding.Category,
                severity = SeverityLabel(finding.Severity),
                finding.Title,
                finding.Detail
            }),
            actions = result.RecommendedActions,
            vba = new
            {
                hasMacro = result.Vba.HasMacro,
                note = VbaAnalysisNote(result.Vba),
                mode = VbaAnalysisModeLabel(result.Vba),
                result.Vba.ModuleCount,
                result.Vba.SourceLineCount,
                result.Vba.SuspiciousKeywordCount,
                result.Vba.DataAccessKeywordCount,
                result.Vba.PersonalInfoPatternCount,
                result.Vba.DetectedObjectTargets,
                result.Vba.DetectedFileTargets,
                result.Vba.DetectedConnectionHints,
                result.Vba.DetectedSqlTables,
                modules = result.Vba.Modules
                    .OrderByDescending(ModuleRiskScore)
                    .ThenBy(module => module.Name)
                    .Take(12)
                    .Select(module => new
                    {
                        module.Name,
                        module.LineCount,
                        summary = ModuleSummary(module),
                        details = ModuleDetails(module)
                    })
            }
        };
    }

    private static IEnumerable<object> BuildReportMetrics(ExcelDiagnosticsResult result)
    {
        yield return new { label = "総シート数", value = result.Structure.TotalSheetCount.ToString() };
        yield return new { label = "非表示シート数", value = result.Structure.HiddenSheetCount.ToString() };
        yield return new { label = "ピボットテーブル", value = result.Structure.PivotTableCount.ToString() };
        yield return new { label = "総数式数", value = result.Logic.TotalFormulaCount.ToString() };
        yield return new { label = "参照関数", value = result.Logic.LookupFunctionCount.ToString() };
        yield return new { label = "揮発性関数", value = result.Logic.VolatileFunctionCount.ToString() };
        yield return new { label = "外部リンク", value = result.Logic.ExternalLinkCount.ToString() };
        yield return new { label = "名前定義", value = result.Logic.DefinedNameCount.ToString() };
        yield return new { label = "セル結合", value = result.Operation.MergedCellCount.ToString() };
        yield return new { label = "条件付き書式", value = result.Operation.ConditionalFormatRuleCount.ToString() };
        yield return new { label = "入力規則", value = result.Operation.DataValidationCount.ToString() };
        yield return new { label = "保護シート", value = result.Operation.ProtectedSheetCount.ToString() };
    }

    private static string ScoreRingStyle(int score)
    {
        var color = score switch
        {
            >= 85 => "#17803a",
            >= 70 => "#2563eb",
            >= 55 => "#b7791f",
            >= 40 => "#c2410c",
            _ => "#b42318"
        };

        return $"background: conic-gradient({color} {score}%, #e5e7eb 0);";
    }

    private static string ScoreComment(int score) => score switch
    {
        >= 85 => "大きなリスクは少なく、管理しやすい状態です。",
        >= 70 => "一部に見直し余地がありますが、致命的な複雑化は限定的です。",
        >= 55 => "属人化や保守負荷が見え始めています。棚卸しを推奨します。",
        >= 40 => "業務依存や保守性のリスクが高く、改善計画が必要です。",
        _ => "ブラックボックス化が強く、早急なリファクタリング対象です。"
    };

    private static string AssessmentTitle(ExcelDiagnosticsResult result)
    {
        var highCount = result.Findings.Count(finding => finding.Severity == "High");

        if (highCount >= 3)
        {
            return "優先的な棚卸しが必要な Excel です";
        }

        if (result.Vba.HasMacro || result.Logic.ExternalLinkCount > 0)
        {
            return "外部依存とマクロ観点の確認が必要です";
        }

        if (result.HealthScore >= 85)
        {
            return "管理しやすい状態を保っています";
        }

        return "保守性と属人化の見直し余地があります";
    }

    private static string AssessmentSummary(ExcelDiagnosticsResult result)
    {
        var highCount = result.Findings.Count(finding => finding.Severity == "High");
        return $"検出リスク {result.Findings.Count} 件、高リスク {highCount} 件。総数式 {result.Logic.TotalFormulaCount:N0} 件、外部依存 {result.Logic.ExternalLinkCount + result.Vba.DataAccessKeywordCount:N0} 件を確認しました。";
    }

    private static IEnumerable<(string Label, int Percent)> RiskBars(ExcelDiagnosticsResult result)
    {
        yield return ("セキュリティ", ClampPercent(result.Vba.SuspiciousKeywordCount * 25 + (result.Vba.HasMacro ? 20 : 0)));
        yield return ("属人化", ClampPercent(result.Structure.HiddenSheetCount * 18 + result.Operation.ProtectedSheetCount * 15 + result.Vba.PersonalInfoPatternCount * 20));
        yield return ("保守性", ClampPercent(result.Logic.TotalFormulaCount / 20 + result.Logic.LookupFunctionCount / 4 + result.Operation.MergedCellCount / 6));
        yield return ("業務依存", ClampPercent(result.Logic.ExternalLinkCount * 30 + result.Vba.DataAccessKeywordCount * 18));
    }

    private static int ClampPercent(int value) => Math.Clamp(value, 0, 100);

    private static IEnumerable<(string Rank, string Label)> RankScale()
    {
        yield return ("A", "85-100");
        yield return ("B", "70-84");
        yield return ("C", "55-69");
        yield return ("D", "40-54");
        yield return ("E", "0-39");
    }

    private static string MetricTone(int value, int warnAt = 1, int dangerAt = 5)
    {
        if (value >= dangerAt)
        {
            return "danger";
        }

        if (value >= warnAt)
        {
            return "warn";
        }

        return string.Empty;
    }

    private static string SeverityClass(string severity) => severity switch
    {
        "High" => "severity-high",
        "Medium" => "severity-medium",
        _ => "severity-low"
    };

    private static string SeverityLabel(string severity) => severity switch
    {
        "High" => "高",
        "Medium" => "中",
        _ => "低"
    };

    private static string VbaAnalysisNote(VbaDiagnostics vba)
    {
        if (!vba.HasMacro)
        {
            return "このブックには VBA マクロは含まれていません。";
        }

        if (!vba.DetailedAnalysisCompleted)
        {
            return "初回診断ではマクロ有無と保護痕跡のみを確認しています。CreateObject の対象、参照ファイル、SQL テーブル候補を調べるには VBA 詳細解析を実行してください。";
        }

        if (vba.SourceCodeParsed)
        {
            return "VBA 圧縮ストリームを展開し、モジュール単位でソースコード上の注意語句と外部依存を解析しています。";
        }

        return "VBA ソースの展開はできなかったため、vbaProject.bin のバイナリ痕跡から注意語句と外部依存を推定しています。";
    }

    private static string VbaAnalysisModeLabel(VbaDiagnostics vba)
    {
        if (!vba.HasMacro)
        {
            return "なし";
        }

        if (!vba.DetailedAnalysisCompleted)
        {
            return "未実行";
        }

        return vba.SourceCodeParsed ? "ソース" : "痕跡";
    }

    private static int ModuleRiskScore(VbaModuleDiagnostics module) =>
        module.SuspiciousKeywordCount * 4 +
        module.DataAccessKeywordCount * 3 +
        module.PersonalInfoPatternCount * 2 +
        module.DetectedSqlTables.Count;

    private static string ModuleSummary(VbaModuleDiagnostics module)
    {
        if (ModuleRiskScore(module) == 0)
        {
            return "目立つ注意語句は検出されませんでした。";
        }

        return $"注意語句 {module.SuspiciousKeywordCount} 件、外部依存語句 {module.DataAccessKeywordCount} 件、固定情報パターン {module.PersonalInfoPatternCount} 件を検出しました。";
    }

    private static string ModuleDetails(VbaModuleDiagnostics module)
    {
        var items = module.DetectedKeywords
            .Concat(module.DetectedDependencies)
            .Concat(module.DetectedObjectTargets.Select(target => $"Object:{target}"))
            .Concat(module.DetectedFileTargets.Select(path => $"File:{path}"))
            .Concat(module.DetectedSqlTables.Select(table => $"SQL:{table}"))
            .Distinct()
            .Take(12);

        return $"検出内容: {string.Join(", ", items)}";
    }
}
